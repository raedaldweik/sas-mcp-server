# Required
VIYA_ENDPOINT=

# Optional
CLIENT_ID=sas-mcp
# Only needed if you registered a confidential OAuth client (one with a
# secret). Leave empty for a public/PKCE client (the default registration).
CLIENT_SECRET=
HOST_PORT=8134
MCP_SIGNING_KEY=default # Should be a strong random string in production
MCP_BASE_URL= # External URL of the MCP server (e.g. https://sas-mcp.company.com) — defaults to http://localhost:HOST_PORT
COMPUTE_CONTEXT_NAME=SAS Job Execution compute context

# Cap the characters of each execute_sas_code log/listing field so a verbose
# PROC can't overflow the agent's context window (important for RAM/agent use).
# Set 0 to disable.
MAX_SAS_OUTPUT_CHARS=12000

# Safety net: maximum seconds to poll a single compute job before giving up, so
# a stuck job can't hang the agent forever. Default 3600 (1 hour) is generous so
# legitimate long PROCs/large-data steps are unaffected; raise it for very long
# workloads, lower it for snappier failure.
JOB_POLL_TIMEOUT=3600

# Set to false to disable SSL verification (e.g. for self-signed Viya certificates)
SSL_VERIFY=true

# ---------------------------------------------------------------------------
# Headless authentication (stdio mode and direct HTTP mode)
# ---------------------------------------------------------------------------
# These modes log the server into Viya itself. Pick ONE of the two options:
#
# Option 1 (recommended) — Refresh token. Required when your Viya users sign
# in through an external identity provider (e.g. Okta SSO): the password grant
# below CANNOT authenticate federated users. Obtain a refresh token once with
#   uv run python examples/get_refresh_token.py
# then paste it here. The server exchanges it for access tokens automatically,
# carrying your full identity/privileges, with no browser and no stored
# password. Ideal for unattended 24/7 deployments (e.g. SAS Retrieval Agent
# Manager). Store it as a *secret* wherever you deploy.
VIYA_REFRESH_TOKEN=

# Option 2 — Username/password (password grant). Works only for accounts SAS
# Logon authenticates directly (e.g. the local `sasboot` account or LDAP
# users); it does NOT work for Okta/SSO-federated users. Used only when
# VIYA_REFRESH_TOKEN is empty.
VIYA_USERNAME=
VIYA_PASSWORD=

# Optional for direct HTTP mode (app-http-direct): protect the MCP endpoint
# with a static API key. Clients send it as X-API-Key or Authorization: Bearer.
MCP_API_KEY=

# Optional for direct HTTP mode: transport protocol — "http" (streamable HTTP,
# endpoint /mcp, default) or "sse" (Server-Sent Events, endpoint /sse).
MCP_TRANSPORT=http

# ---------------------------------------------------------------------------
# Use-case scoping (optional)
# ---------------------------------------------------------------------------
# Restrict this assistant to a curated subset of the environment. When none of
# the ALLOWED_* variables are set, the server has full access (default). When
# any are set, list tools return only the allowed resources and (unless
# SCOPE_ENFORCE=false) out-of-scope access is blocked. Entries may be IDs or
# names; tables may be table, caslib.table, or server.caslib.table.
USE_CASE_NAME=
USE_CASE_DESCRIPTION=
ALLOWED_TABLES=
ALLOWED_MODELS=
ALLOWED_DECISIONS=
SCOPE_ENFORCE=true

# ---------------------------------------------------------------------------
# Container mode (optional)
# ---------------------------------------------------------------------------
# Which server the container runs: http-direct (default, for RAM hosting),
# http (OAuth PKCE), or stdio. Ignored outside the Docker image.
MCP_MODE=http-direct